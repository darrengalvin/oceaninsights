# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://vecclmzkzrwsrtokkclr.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# This is the service role key - KEEP SECRET
# Only used server-side for admin operations
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Resend - for sending sponsorship invite emails
# Sign up at https://resend.com, verify your sending domain, paste the key here
RESEND_API_KEY=re_...
# Address invites are sent FROM (must match a verified Resend sender)
RESEND_FROM_EMAIL=invites@belowthesurface.app
RESEND_FROM_NAME=Below the Surface

# Public URL of this admin/marketing site (used in invite magic links)
NEXT_PUBLIC_SITE_URL=https://admin-pi-eosin-53.vercel.app



