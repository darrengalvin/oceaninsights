# Copy this file to key.properties and fill in your values.
# key.properties is gitignored and must never be committed.
#
# Create a keystore (one-time) with:
#   keytool -genkey -v -keystore android/app/upload-keystore.jks -storetype JKS -keyalg RSA -keysize 2048 -validity 10000 -alias upload
#
# Then fill in below. storeFile is relative to the android/ folder.
storePassword=your_keystore_password
keyPassword=your_key_password
keyAlias=upload
storeFile=app/upload-keystore.jks
